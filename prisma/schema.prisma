// ==========================================
// ⚠️  AUTO-GERADO. NÃO EDITE ESTE ARQUIVO.
// Fonte: prisma/schema/*.prisma
// ==========================================

// ----- 00-generator.prisma -----
generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

// ----- 01-datasource.prisma -----
datasource db {
  provider = "postgresql"
}

// ----- 10-enums.prisma -----


// ----- 20-mural.model.prisma -----
model Mural {
    id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
    titulo          String
    mensagem        String
    caminhoImagem   String?
    ativo           Boolean         @default(true)
    validoAte       String
    criadoPor       String 
    importante      Boolean         @default(false)         

    filiais         String[]

    createdAt       DateTime        @default(now()) @map("createdAt") @db.Timestamp(6)
    updatedAt       DateTime        @default(now()) @updatedAt @map("updatedAt") @db.Timestamp(6)

  @@map("Mural")
}

// ----- 21-auditLog.model.prisma -----
model AuditLog {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  acao              String
  entidade          String
  ipAddress         String?
  filialEntidade    String?

  createdAt         DateTime    @default(now())

  @@map("audit_logs")
}

// ----- 22-assinatura.model.prisma -----
model Assinatura {
    id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
    nome            String
    departamento    String
    telefone        String?         
    email           String
    criadoPor       String 
    caminhoImagem   String?
    status          String?         @default("AGUARDANDO APROVAÇÃO")
    motivo          String?         
    
    createdAt       DateTime        @default(now()) @map("createdAt") @db.Timestamp(6)
    updatedAt       DateTime        @default(now()) @updatedAt @map("updatedAt") @db.Timestamp(6)

  @@map("Assinatura")
}

// ----- 23-toDo.model.prisma -----
model ToDo {
    id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
    nome                String
    descricao           String
    prazoLimite         String?         
    responsavel         String
    finalizado          Boolean         @default(false) 
    dataFinalizado      String?
    
    createdAt       DateTime            @default(now()) @map("createdAt") @db.Timestamp(6)
    updatedAt       DateTime            @default(now()) @updatedAt @map("updatedAt") @db.Timestamp(6)

  @@map("ToDo")
}

// ----- 24-contasOffice.model.prisma -----
model ContasOffice {
    id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
    nome            String
    email           String
    senha           String
    ativo           Boolean         @default(false)

    @@map("ContasOffice")
}

// ----- 25-inventarioImpressoras.model.prisma -----
model InventarioImpressoras {
    id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
    filial                  String
    marca                   String
    modelo                  String
    numeroSerie             String?
    ip                      String
    macLan                  String
    macWlan                 String?
    localizacao             String?
    senhaAdministrador      String?
    etiqueta                String?

    createdAt               DateTime        @default(now()) @map("createdAt") @db.Timestamp(6)
    updatedAt               DateTime        @default(now()) @updatedAt @map("updatedAt") @db.Timestamp(6)

  @@map("InventarioImpressoras")
}

// ----- 26-pops.model.prisma -----
model Pops {
    id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
    filename                String
    originalName            String
    mimetype                String
    size                    String
    filePath                String
    folder                  String
   
    createdAt               DateTime        @default(now()) @map("createdAt") @db.Timestamp(6)
    updatedAt               DateTime        @default(now()) @updatedAt @map("updatedAt") @db.Timestamp(6)

  @@map("Pops")
}

// ----- 27-plantaoConfig.model.prisma -----
model PlantaoConfig {
  id                        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  janelaSisInicio           String           
  janelaSisFim              String           
  janelaInfInicio           String           
  janelaInfFim              String           
  escalaSistemas            Json             
  escalaInfra               Json             

  createdAt                 DateTime        @default(now()) @map("createdAt") @db.Timestamp(6)
  updatedAt                 DateTime        @default(now()) @updatedAt @map("updatedAt") @db.Timestamp(6)
  
  contatos                  PlantaoContato[]

  @@map("PlantaoConfig")
}

// ----- 28-plantaoContato.model.prisma -----
enum Area {
  Sistemas
  Infra
}

model PlantaoContato {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
  nome                  String
  telefone              String
  area                  Area

  createdAt             DateTime        @default(now()) @map("createdAt") @db.Timestamp(6)
  updatedAt             DateTime        @default(now()) @updatedAt @map("updatedAt") @db.Timestamp(6)

  configId              String          @db.Uuid
  config                PlantaoConfig   @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("PlantaoContato")
}

// ----- 29-assinaturaPadrao.model.prisma -----
model AssinaturaPadrao {
    id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("id")
    caminhoBackground       String?
    corFont                 String?
    fontSize                String?

    photoX                  Int?
    photoY                  Int?
    photoSize               Int?

    nomeX                   Int?
    nomeY                   Int?

    departamentoX           Int?
    departamentoY           Int?

    telefoneX               Int?
    telefoneY               Int?

    logoX                   Int?
    logoY                   Int?
    logoHeight              Int?

    criadoPor               String?
    isAtual                 Boolean         @default(true)        
    
    createdAt               DateTime        @default(now()) @map("createdAt") @db.Timestamp(6)
    updatedAt               DateTime        @default(now()) @updatedAt @map("updatedAt") @db.Timestamp(6)

  @@map("AssinaturaPadrao")
}
